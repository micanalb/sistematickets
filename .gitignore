# ─────────────────────────────────────────────────────────────────
# TicketsYa — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Variables de entorno (NUNCA subir al repo) ─────────────────────
.env
*.env
!*.env.example

# ── Go ─────────────────────────────────────────────────────────────
backend/ticketsya-server
backend/ticketsya
*.exe
*.test
*.out
/tmp/

# ── Node / Frontend ────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Docker ─────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Sistema operativo ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDEs ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace

# ── Logs ───────────────────────────────────────────────────────────
*.log
logs/

# ── Coverage de tests ──────────────────────────────────────────────
coverage.out
coverage.html
